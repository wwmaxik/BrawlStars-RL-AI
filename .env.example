# ==========================================
# Brawl Stars RL Bot - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values

# --- Window Configuration ---
# Window name for BlueStacks (must match exactly)
WINDOW_NAME="Bluestacks App Player"

# --- Hardware Configuration ---
# Set to True if you have an NVIDIA GPU with CUDA
USE_NVIDIA_GPU=True

# --- YOLOv8 Model Path ---
# Path to your trained YOLOv8 model
# For GPU: yolov8_model/yolov8.pt
# For CPU (OpenVINO): yolov8_model/yolov8_openvino_model
YOLO_MODEL_PATH=yolov8_model/yolov8.pt

# --- YOLO Inference Settings ---
# Image size for YOLO inference (width, height)
YOLO_IMG_SIZE=(384, 640)

# Use half precision (FP16) for faster inference on GPU
YOLO_HALF_PRECISION=True

# Detection thresholds for each class: [Player, Bush, Enemy, Cubebox]
# Format: comma-separated floats
YOLO_THRESHOLDS=0.37,0.47,0.57,0.65

# --- RL Training Settings ---
# Frame stacking size (number of consecutive frames)
FRAME_STACK=4

# Image size for CNN observation (84x84 is standard)
CNN_IMG_SIZE=84

# Total training steps (increase for better results)
TOTAL_TIMESTEPS=2000000

# --- Dashboard Settings ---
# Web dashboard port
DASHBOARD_PORT=5000

# TensorBoard log directory
TENSORBOARD_LOG_DIR=./logs/tensorboard

# --- Logging ---
# Enable verbose logging (True/False)
VERBOSE_LOGGING=False
